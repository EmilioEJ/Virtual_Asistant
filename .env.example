# Copia este archivo a .env en el servidor y completa los valores.
# El .env real NO se comitea (está en .gitignore).

# Dominio público (usado por las labels de Traefik).
DOMAIN=aria.indoamericatech.com

# Proveedor de IA: el modelo vive en el GPU (LabITI), accedido por el sidecar autossh.
AI_PROVIDER=openwebui
OPENWEBUI_BASE_URL=http://aria-ollama-tunnel:11434/v1
OPENWEBUI_MODEL_NAME=qwen3:14b
OPENWEBUI_API_KEY=ollama            # dummy: solo debe ser no vacío para Ollama

# Voz -> texto (Whisper en Groq). Opcional: sin esta key, /api/stt queda deshabilitado.
GROQ_API_KEY=

# Voz (TTS con ElevenLabs). Requerido por /api/tts; sin esta key la síntesis de voz da error 500.
ELEVENLABS_API_KEY=

# Fallback opcional en la nube (si algún día se cambia AI_PROVIDER=gemini).
GEMINI_API_KEY=
